#!/bin/bash
# ============================================
# secrets-lock: Encrypt secrets/ → secrets.enc
# Usage: secrets-lock [--save-key]
#   --save-key: Save password to keyfile for automation
# ============================================

PROFILE_ROOT="/home1/irteam/data-vol1/profile"
SECRETS_DIR="$PROFILE_ROOT/secrets"
ENCRYPTED_FILE="$PROFILE_ROOT/secrets.enc"
KEYFILE="/home1/irteam/data-vol1/.secrets_key"

if [ ! -d "$SECRETS_DIR" ] || [ -z "$(ls -A "$SECRETS_DIR" 2>/dev/null)" ]; then
    echo "[secrets] No secrets to encrypt."
    exit 1
fi

# Get password: from keyfile or prompt
if [ -f "$KEYFILE" ]; then
    PASSWORD="$(cat "$KEYFILE")"
else
    read -s -p "Enter password: " PASSWORD
    echo
    read -s -p "Confirm password: " PASSWORD2
    echo
    if [ "$PASSWORD" != "$PASSWORD2" ]; then
        echo "[secrets] Passwords do not match. Aborted."
        exit 1
    fi
fi

# Save key if requested
if [ "$1" = "--save-key" ] && [ ! -f "$KEYFILE" ]; then
    echo -n "$PASSWORD" > "$KEYFILE"
    chmod 600 "$KEYFILE"
    echo "[secrets] Key saved to $KEYFILE"
fi

# tar + encrypt
echo "[secrets] Encrypting secrets/..."
echo "  Files: $(ls "$SECRETS_DIR" | tr '\n' ' ')"

tar -czf - -C "$PROFILE_ROOT" secrets/ | \
    openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 \
    -pass "pass:$PASSWORD" -out "$ENCRYPTED_FILE"

if [ $? -eq 0 ]; then
    echo "[secrets] Encrypted → secrets.enc ($(du -h "$ENCRYPTED_FILE" | cut -f1))"
else
    echo "[secrets] Encryption failed."
    rm -f "$ENCRYPTED_FILE"
    exit 1
fi
