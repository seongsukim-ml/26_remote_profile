#!/bin/bash
# ============================================
# secrets-unlock: Decrypt secrets.enc → secrets/
# Usage: secrets-unlock [--force]
#   --force: Overwrite existing secrets/ without prompt
# ============================================

PROFILE_ROOT="/home1/irteam/data-vol1/profile"
SECRETS_DIR="$PROFILE_ROOT/secrets"
ENCRYPTED_FILE="$PROFILE_ROOT/secrets.enc"
KEYFILE="/home1/irteam/data-vol1/.secrets_key"

if [ ! -f "$ENCRYPTED_FILE" ]; then
    echo "[secrets] No secrets.enc found. Nothing to decrypt."
    exit 1
fi

if [ -d "$SECRETS_DIR" ] && [ -n "$(ls -A "$SECRETS_DIR" 2>/dev/null)" ]; then
    if [ "$1" != "--force" ]; then
        echo "[secrets] secrets/ already exists with files:"
        ls "$SECRETS_DIR"
        read -p "Overwrite? [y/N] " confirm
        [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Aborted."; exit 0; }
    fi
fi

# Get password: from keyfile or prompt
if [ -f "$KEYFILE" ]; then
    PASSWORD="$(cat "$KEYFILE")"
else
    read -s -p "Enter password: " PASSWORD
    echo
fi

# Decrypt + untar
mkdir -p "$SECRETS_DIR"
openssl enc -aes-256-cbc -d -salt -pbkdf2 -iter 100000 \
    -pass "pass:$PASSWORD" -in "$ENCRYPTED_FILE" | \
    tar -xzf - -C "$PROFILE_ROOT"

if [ $? -eq 0 ]; then
    chmod 700 "$SECRETS_DIR"
    chmod 600 "$SECRETS_DIR"/*
    echo "[secrets] Decrypted → secrets/"
    echo "  Files: $(ls "$SECRETS_DIR" | tr '\n' ' ')"
else
    echo "[secrets] Decryption failed. Wrong password?"
    exit 1
fi
